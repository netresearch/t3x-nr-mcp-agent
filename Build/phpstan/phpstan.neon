includes:
    - %currentWorkingDirectory%/.Build/vendor/saschaegerer/phpstan-typo3/extension.neon
    - %currentWorkingDirectory%/.Build/vendor/phpat/phpat/extension.neon

parameters:
    level: 10
    paths:
        - ../../Classes
        - ../../Tests/Architecture
    treatPhpDocTypesAsCertain: false
    scanDirectories:
        - ../../Tests/Architecture
    ignoreErrors:
        # phpoffice/phpspreadsheet is an optional suggested dependency (not required).
        # XlsxExtractor guards usage behind isAvailable(), but PHPStan cannot resolve
        # the classes when the package is not installed.
        - identifier: class.notFound
          path: ../../Classes/Document/Extractor/XlsxExtractor.php
        - identifier: method.nonObject
          path: ../../Classes/Document/Extractor/XlsxExtractor.php
        - identifier: foreach.nonIterable
          path: ../../Classes/Document/Extractor/XlsxExtractor.php
        - identifier: cast.string
          path: ../../Classes/Document/Extractor/XlsxExtractor.php
        - identifier: argument.type
          path: ../../Classes/Document/Extractor/XlsxExtractor.php

services:
    -
        class: Netresearch\NrMcpAgent\Tests\Architecture\LayerDependencyTest
        tags:
            - phpat.test
    -
        class: Netresearch\NrMcpAgent\Tests\Architecture\DocumentExtractorArchitectureTest
        tags:
            - phpat.test
